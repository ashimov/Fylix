# Fylix Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
#
# See docs/DEPLOYMENT.md for the full production bootstrap sequence.

# === Public app config ===
APP_ENV=development
APP_NAME=Fylix
PUBLIC_URL=https://localhost
LOG_LEVEL=info

# === Database ===
POSTGRES_DB=fylix
POSTGRES_USER=fylix
# REQUIRED — generate a strong random password for any non-local deployment.
POSTGRES_PASSWORD=change_me_in_prod

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === MinIO (S3-compatible object storage) ===
MINIO_ROOT_USER=fylix-minio
# REQUIRED — generate a strong random password for any non-local deployment.
MINIO_ROOT_PASSWORD=change_me_in_prod_minio
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=transfers
# Dev: false is fine (internal plain HTTP between api/worker and minio).
# Prod (APP_ENV=production): MUST be true — the app refuses to start otherwise.
# Plain-HTTP ciphertext + access keys on the data network is not acceptable.
MINIO_SECURE=false

# === Master key ===
# Path to a 32-byte binary file (Docker secret in prod, bind-mount in dev).
# Generate it with:
#   openssl rand -base64 32 > secrets/master_key
# or via the provided helper:
#   make master-key
# NEVER commit this file. It is the root key that decrypts every transfer —
# losing it means all stored ciphertext becomes permanently unrecoverable,
# and leaking it means every transfer (past and future, until rotated) can be
# decrypted. Back up the generated value offline (see docs/KEY_ROTATION.md).
MASTER_KEY_PATH=/run/secrets/master_key

# === Staging ===
# Plaintext temp dir, bind-mounted from host so an on-host antivirus/EDR
# agent can scan uploads before they are encrypted. See docs/DEPLOYMENT.md
# section 4 ("Malware scanning integration") for details and alternatives.
STAGING_DIR=/srv/fylix/staging

# === Defaults (seeded into settings table on first migrate) ===
# Do not read these at runtime — they are seeds only. Admin changes
# values through /admin/limits.
DEFAULT_MAX_TRANSFER_SIZE_GB=2
DEFAULT_MAX_TTL_DAYS=7
DEFAULT_RATE_HOURLY=10
DEFAULT_RATE_DAILY=100

# === SMTP (dev default: mailpit; prod: your own relay) ===
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
# Set to false only for internal relays whose self-signed cert doesn't match
# the connecting hostname/IP. Leave true for any public relay (SendGrid,
# SES, Mailgun, corporate relay with a valid cert, etc).
SMTP_VERIFY_CERT=true

# === Telegram bot for admin alerts (empty = disabled) ===
# NEVER commit a real bot token here — copy this file to .env (gitignored)
# and fill credentials there. Revoke any token leaked into a repo via
# @BotFather immediately.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === hCaptcha ===
# Dev: empty disables captcha and verify() passes automatically.
# Prod (APP_ENV=production): MANDATORY. The app refuses to start if empty.
# Get keys at https://www.hcaptcha.com/
HCAPTCHA_SECRET=
HCAPTCHA_SITE_KEY=

# === MaxMind GeoIP (empty = disabled; country detection falls back to null) ===
# Register a free account and download GeoLite2-Country.mmdb — see
# docs/DEPLOYMENT.md section 3 for the exact steps.
MAXMIND_DB_PATH=/srv/fylix/geoip/GeoLite2-Country.mmdb

# === Dev-only cookie relaxation ===
# When APP_ENV=development and using plain http://localhost (no Nginx TLS),
# set to 1 to allow non-Secure cookies.
# Prod (APP_ENV=production): MUST be 0. The app refuses to start otherwise.
DEV_INSECURE_COOKIES=0

# === Observability (optional) ===
# GlitchTip/Sentry DSN for error reporting. Empty = disabled.
SENTRY_DSN=
# Frontend build-time DSN (public UI errors). Empty = disabled.
VITE_SENTRY_DSN=
# OTLP gRPC endpoint for traces (Jaeger by default in the dev compose stack).
# Set to empty to disable tracing entirely.
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_TRACES_SAMPLER_ARG=1.0

# === Grafana (observability stack, dev/docker-compose only) ===
GRAFANA_ADMIN_USER=admin
# REQUIRED — change from the default before exposing Grafana beyond localhost.
GRAFANA_ADMIN_PASSWORD=change_me_in_prod

# === Advanced (optional — sane defaults, rarely need changing) ===
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# MINIO_ENDPOINT=minio:9000
# CLEANUP_INTERVAL_SECONDS=300
# DEFENDER_POLL_ENABLED=true
# RATE_LIMIT_CACHE_TTL=10
# SENTRY_TRACES_SAMPLE_RATE=0.1
# MASTER_KEY_PREVIOUS_PATH=   # only set during a master-key rotation window
