    "/api/admin/audit.csv": {
      "get": {
        "description": "Stream the audit log as CSV for a bounded date window.\n\n    The previous implementation materialised the entire filtered table into\n    RAM before yielding the first byte — that is an OOM risk at 10M+ rows.\n    This version streams via `session.stream_scalars` and enforces a hard\n    90-day window ceiling so a single export can't drag the database into\n    an unbounded sequential scan either.",
        "operationId": "admin_audit_csv",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            },
            "description": "Successful response"
          }
        },
        "summary": "Stream the audit log as CSV for a bounded date window.",
        "tags": [
          "admin"
        ]
      }
    },
