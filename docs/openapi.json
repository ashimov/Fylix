    "/api/admin/crypto/rewrap": {
      "post": {
        "description": "Rewrap all `transfers.wrapped_key` and `admins.totp_secret` rows from\n    the previous master key to the current master key.\n\n    Preconditions (enforced by 409):\n      - A rotation window is active (`MASTER_KEY_PREVIOUS_PATH` set, so\n        `get_previous_master_key()` returns non-None).\n      - Current and previous keys differ.\n\n    The operation is idempotent: re-running after a partial crash (or just\n    because) is safe — AES-KW RFC 3394 is deterministic, so rewrapping a\n    blob already under the current key returns the identical bytes. Rows\n    commit in chunks of _REWRAP_CHUNK so a crash mid-run leaves the DB in\n    a partially-migrated state that the next run completes.",
        "operationId": "admin_crypto_rewrap",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "object"
                  },
                  "type": "object"
                }
              }
            },
            "description": "Successful response"
          }
        },
        "summary": "Rewrap all `transfers.wrapped_key` and `admins.totp_secret` rows from",
        "tags": [
          "admin"
        ]
      }
    },
