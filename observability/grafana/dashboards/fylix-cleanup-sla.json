{
  "uid": "fylix-cleanup-sla",
  "title": "Fylix — Crypto-shred SLA (cleanup heartbeat)",
  "tags": ["fylix", "sla", "security"],
  "timezone": "",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Cleanup heartbeat age",
      "description": "Seconds since the worker last marked expired transfers as deleted. Target: ≤ 5 min cadence. Alert threshold: 10 min. If breached, expired ciphertext remains on MinIO past its TTL and wrapped keys remain decryptable — crypto-shred SLA violation.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "time() - fylix_cleanup_last_run_timestamp", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 300 },
              { "color": "red", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Heartbeat age over time",
      "description": "Sawtooth pattern is healthy — worker ticks every 5 min so the age climbs 0→300s repeatedly. A flat rising line = worker stopped ticking.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "time() - fylix_cleanup_last_run_timestamp",
          "legendFormat": "age (s)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 600 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Last cleanup ran at (unix ts)",
      "gridPos": { "h": 5, "w": 24, "x": 0, "y": 8 },
      "targets": [
        { "expr": "fylix_cleanup_last_run_timestamp", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dateTimeAsIso",
          "mappings": [
            { "options": { "0": { "text": "never (worker not started)" } }, "type": "value" }
          ]
        }
      }
    }
  ]
}
